DJANGO_SECRET_KEY=development-only-change-me
DJANGO_DEBUG=1
DATABASE_URL=postgresql://kubeops:kubeops@localhost:5432/kubeops
KUBEOPS_SCENARIO_DIR=./scenarios
KUBEOPS_PROFILE_DIR=./profiles
KUBEOPS_ARTIFACT_DIR=./artifacts
KUBEOPS_LIVE_EXECUTION_ENABLED=0
KUBEOPS_OPERATION_DIR=./operations
KUBEOPS_POLICY_DIR=./policies
KUBEOPS_LIFECYCLE_DIR=./lifecycle
VITE_API_BASE_URL=http://localhost:8000/api/v1
KUBEOPS_PACK_DIR=./packs
# Empty enables every successfully resolved installed pack.
KUBEOPS_ENABLED_PACKS=

# Release 1.0 production controls
DJANGO_ALLOWED_HOSTS=localhost
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0
KUBEOPS_ALLOW_ANONYMOUS_READ=1
KUBEOPS_DEFAULT_ORGANIZATION_ID=default
KUBEOPS_DEFAULT_WORKSPACE_ID=default
KUBEOPS_RETENTION_APPLY_ENABLED=0
KUBEOPS_BACKUP_DIR=./backups
KUBEOPS_PACK_TRUST_KEY_ID=release-key
KUBEOPS_PACK_TRUST_SECRET_ENV=KUBEOPS_PACK_TRUST_SECRET
KUBEOPS_PACK_TRUST_SECRET=
KUBEOPS_EXECUTOR_OFFLINE_SECONDS=120

# Set to s3 for horizontally scaled API deployments.
KUBEOPS_ARTIFACT_BACKEND=file
KUBEOPS_ARTIFACT_S3_BUCKET=
KUBEOPS_ARTIFACT_S3_PREFIX=kubeops
KUBEOPS_ARTIFACT_S3_ENDPOINT=
KUBEOPS_ARTIFACT_S3_REGION=
KUBEOPS_RESTORE_ENABLED=0
KUBEOPS_AUDIT_REQUIRED=0
KUBEOPS_PACK_TRUST_PUBLIC_KEY_ENV=KUBEOPS_PACK_TRUST_PUBLIC_KEY
KUBEOPS_PACK_TRUST_PUBLIC_KEY=
KUBEOPS_EXECUTOR_AGENT_ID=local-executor
KUBEOPS_EXECUTOR_CAPABILITIES=executor.claim,executor.complete,observe
KUBEOPS_EXECUTOR_IDS=dry_run,simulation,builtin.wait
KUBEOPS_EXECUTOR_MAX_CONCURRENCY=1
KUBEOPS_EXECUTOR_POLL_SECONDS=2
